# Copy to .env and fill from your teacher's shared connection string.
#
# Two ways to load this file:
#   1. `set -a && source .env && set +a` — exports every assignment to the
#      environment so python3 subprocesses inherit it. The value below MUST
#      be double-quoted: unquoted semicolons break a naive `source`.
#   2. `python-dotenv` from inside Python: `from dotenv import load_dotenv; load_dotenv()`.
#      Either form of the value works with python-dotenv.
#
# Plain `source .env` without `set -a` only sets shell variables (not env vars),
# so Python will report the connection string as not set.
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>;EndpointSuffix=core.windows.net"
