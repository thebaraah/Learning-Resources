{
    "name": "HYF Learning Resources",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        },
        "ghcr.io/devcontainers/features/azure-cli:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "charliermarsh.ruff",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "usernamehw.errorlens"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.formatOnSave": true
                },
                "[javascript]": {
                    "editor.defaultFormatter": "esbenp.prettier-vscode",
                    "editor.formatOnSave": true
                }
            }
        }
    },
    "workspaceFolder": "/workspaces/Learning-Resources",
    "postCreateCommand": "echo '✅ HYF Codespace ready. Data Track exercises: data-track/week-N/exercise_X/. Core program: core-program/week-N/. Install JS deps per exercise: cd core-program/week-N/<exercise> && npm install'",
    "remoteUser": "vscode"
}
